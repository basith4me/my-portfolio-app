# EmailJS Configuration (Optional - can also hardcode in Contact.jsx)
# Get your credentials from https://www.emailjs.com/

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Instructions:
# 1. Copy this file and rename to .env
# 2. Replace values with your actual EmailJS credentials
# 3. Access in code: import.meta.env.VITE_EMAILJS_SERVICE_ID
# 4. Never commit .env to version control
